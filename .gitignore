# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design review screenshots (large, not for repo)
/.design-review/
/.qa-screens/
/.playwright-mcp/

# local IDE / agent config (not for repo)
/.cursor/
/.claude/

# favicon exploration artifacts (production assets live in public/)
/brand/favicon-options/
/public/favicon-options/
/public/favicon-preview.html
/public/favicon-preview-marek2.html

# stray unrelated file (do not commit)
/x_curiosity.png
